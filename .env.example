# Boltable / local server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
SFOOD_DEPLOY_TARGET=boltable
SFOOD_CACHE_TTL_MS=60000

# Looker API (https://bolt.cloud.looker.com)
LOOKER_BASE_URL=https://bolt.cloud.looker.com
LOOKER_CLIENT_ID=
LOOKER_CLIENT_SECRET=
LOOKER_MODEL=curated
LOOKER_EXPLORE=fact_order_delivery
LOOKER_TIMEZONE=Europe/Bucharest

# Salesforce OAuth password flow
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# Optional: set when frontend is hosted separately from the API
# NEXT_PUBLIC_API_BASE=
